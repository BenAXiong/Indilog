# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Translation (FormoBank Modal inference) ───────────────────────────────────
# Server-side only — must NOT have NEXT_PUBLIC_ prefix (security requirement)
# Leave blank to use the built-in mock fallback (returns a placeholder translation)
INFERENCE_API_URL=https://your-modal-endpoint.modal.run
INFERENCE_API_KEY=your-modal-api-key

# ── Dictionary corpus ─────────────────────────────────────────────────────────
# No env var needed — place ycm_master.db at packages/dictionary/ycm_master.db
# The app detects it automatically at runtime (see lib/corpus/db.ts)
